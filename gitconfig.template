[user]
	name = __FULL_NAME__
	email = __EMAIL__

[init]
	defaultBranch = main

[pull]
	rebase = false

[push]
	default = current
	autoSetupRemote = true

[core]
	editor = code --wait
	autocrlf = input

[color]
	ui = auto

[alias]
	st = status
	co = checkout
	br = branch
	ci = commit
	last = log -1 HEAD
	lg = log --oneline --graph --decorate -20
	unstage = reset HEAD --
